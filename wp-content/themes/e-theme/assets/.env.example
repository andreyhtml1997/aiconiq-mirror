# WordPress REST API Configuration
NEXT_PUBLIC_WP_REST_URL=/wp-json/
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# LiveKit Voice Agent Configuration
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_AGENT_NAME=aiconiq-agent

# Optional: Calendly Integration
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-calendly-url

# Optional: Tavus Avatar Configuration
NEXT_PUBLIC_TAVUS_PARTICIPANT_NAME=tavus-avatar-agent
